# 运行示例 vault 前，请先复制为 .env
# Copy this file to .env before running the example vault.

# 示例 vault 默认使用 mock；只有切换到真实 provider 时才需要填写这些值。
# The demo vault defaults to mock; only fill these values when switching to a real provider.
OPENAI_API_KEY=your_openai_key
OPENAI_FALLBACK_API_KEY=
ANTHROPIC_API_KEY=your_anthropic_key
