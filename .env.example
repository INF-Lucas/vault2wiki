# 复制到你的 vault 中并命名为 .env
# Copy this file into your vault as .env

# 只填写你实际使用的 provider；未使用的条目可以留空。
# Fill only the provider entries you actually use; leave the others blank.

# OpenAI
OPENAI_API_KEY=your_openai_key

# 可选：OpenAI-compatible 主端点或备用端点也可以共用这些变量名
# Optional: these env vars also work for OpenAI-compatible primary/fallback endpoints
OPENAI_FALLBACK_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_key
